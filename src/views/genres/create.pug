extends ../layout/layout.pug

block metadata
  title Nuevo Género | Biblioteca
  meta(name='description', content='Crear nuevo género literario')

block content
  include ../mixins/components.pug
  .flex.justify-between.items-center.mb-6
    h1.text-2xl.font-medium.text-primary-900 Nuevo Género
    a(href='/genres' class='px-4 py-2 rounded-lg border border-primary-600 text-primary-600 hover:bg-primary-50 transition-colors') Volver
  +card('Datos del género')
    +alert(errors)
    form(action='/genres' method='POST')
      +input('Descripción', 'description', 'text', '', 'Ej: Ciencia Ficción')
      +button('Guardar', 'submit', 'primary')