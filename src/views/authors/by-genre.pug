extends ../layout/layout.pug

block metadata
  title Autores por Género | Biblioteca
  meta(name='description', content='Autores con participación mayor al 50% en un género')

block content
  include ../mixins/components.pug
  div(class='flex justify-between items-center mb-6')
    h1(class='text-2xl font-medium text-primary-900') Autores por género
    a(href='/authors' class='px-4 py-2 rounded-lg border border-primary-600 text-primary-600 hover:bg-primary-50 transition-colors') Volver

  if authors && authors.length
    div(class='grid grid-cols-1 gap-4')
      each author in authors
        +card()
          div(class='flex justify-between items-center')
            div(class='flex items-center gap-4')
              if author.photo
                img(src=author.photo alt=`${author.first_name} ${author.last_name}` class='w-12 h-12 rounded-full object-cover')
              else
                div(class='w-12 h-12 rounded-full bg-primary-200 flex items-center justify-center')
                  span(class='font-medium text-primary-800')= author.first_name[0] + author.last_name[0]
              div
                a(href=`/authors/${author.id}` class='font-medium text-primary-600 hover:text-primary-800 transition-colors')= `${author.first_name} ${author.last_name}`
                p(class='text-sm text-primary-200')= author.email
  else
    p(class='text-primary-200') No hay autores con participación mayor al 50% en este género