extends ../layout/layout.pug

block metadata
  title Nuevo Autor | Biblioteca
  meta(name='description', content='Crear nuevo autor')

block content
  include ../mixins/components.pug
  .flex.justify-between.items-center.mb-6
    h1.text-2xl.font-medium.text-primary-900 Nuevo Autor
    a(href='/authors' class='px-4 py-2 rounded-lg border border-primary-600 text-primary-600 hover:bg-primary-50 transition-colors') Volver
  +card('Datos del autor')
    +alert(errors)
    form(action='/authors' method='POST')
      +input('Nombre', 'first_name', 'text', '', 'Ej: Gabriel')
      +input('Apellido', 'last_name', 'text', '', 'Ej: García Márquez')
      +input('Documento', 'id_card', 'text', '', 'Ej: 12345678')
      +input('Email', 'email', 'email', '', 'Ej: autor@mail.com')
      +input('Foto (URL)', 'photo', 'url', '', 'https://...')
      +button('Guardar', 'submit', 'primary')