extends ../layout/layout.pug

block metadata
  title Editar Libro | Biblioteca
  meta(name='description', content='Editar libro')

block content
  include ../mixins/components.pug
  .flex.justify-between.items-center.mb-6
    h1.text-2xl.font-medium.text-primary-900 Editar Libro
    a(href='/books' class='px-4 py-2 rounded-lg border border-primary-600 text-primary-600 hover:bg-primary-50 transition-colors') Volver

  +card('Datos del libro')
    +alert(errors)
    form(action=`/books/${book.isbn}/edit` method='POST')
      +input('ISBN', 'isbn', 'text', book.isbn, '')
      +input('Título', 'title', 'text', book.title, '')
      +input('Descripción', 'description', 'text', book.description, '')
      +input('Año', 'year', 'number', book.year, '')
      +input('Páginas', 'pages_number', 'number', book.pages_number, '')

      .flex.flex-col.gap-1.mb-4
        label.text-sm.font-medium.text-primary-900(for='genre_id') Género
        select#genre_id.border.border-primary-200.rounded-lg.px-3.py-2(name='genre_id')
          each genre in genres
            option(value=genre.id selected=genre.id === book.genre_id)= genre.description

      .flex.flex-col.gap-1.mb-4
        label.text-sm.font-medium.text-primary-900 Autores
        each author in authors
          - const bookAuthor = bookAuthors.find(ba => ba.author_id === author.id)
          .flex.items-center.gap-3.mb-2
            input(
              type='checkbox'
              name='author_ids'
              value=author.id
              id=`author_${author.id}`
              checked=!!bookAuthor
            )
            label(for=`author_${author.id}`)= `${author.first_name} ${author.last_name}`
            input(
              type='number'
              name='percentages'
              placeholder='% participación'
              min='0'
              max='100'
              value=bookAuthor ? bookAuthor.participation_pct : ''
              class='border border-primary-200 rounded-lg px-2 py-1 w-32'
            )

      +button('Guardar', 'submit', 'primary')