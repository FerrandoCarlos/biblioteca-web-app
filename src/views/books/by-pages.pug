extends ../layout/layout.pug

block metadata
  title Libros por páginas | Biblioteca
  meta(name='description', content='Libros filtrados por cantidad de páginas')

block content
  include ../mixins/components.pug
  div(class='flex justify-between items-center mb-6')
    h1(class='text-2xl font-medium text-primary-900') Libros con más de #{min_pages} páginas
    a(href='/books' class='px-4 py-2 rounded-lg border border-primary-600 text-primary-600 hover:bg-primary-50 transition-colors') Volver

  +card('Filtrar por páginas')
    form(action='/books/pages' method='GET')
      div(class='flex gap-4 items-end')
        div(class='flex flex-col gap-1')
          label(class='text-sm font-medium text-primary-900' for='min_pages') Mínimo de páginas
          input(
            type='number'
            id='min_pages'
            name='min_pages'
            value=min_pages
            placeholder='Ej: 300'
            class='border border-primary-200 rounded-lg px-3 py-2 focus:outline-none focus:border-primary-600'
          )
        button(type='submit' class='px-4 py-2 rounded-lg bg-primary-600 text-primary-50 hover:bg-primary-800 transition-colors') Buscar

  if books && books.length
    div(class='grid grid-cols-1 gap-4')
      each book in books
        +card()
          div(class='flex justify-between items-center')
            div
              p(class='font-medium text-primary-900')= book.title
              p(class='text-sm text-primary-200')= `${book.genre} — ${book.year}`
            span(class='text-sm font-medium text-teal-400')= `${book.pages_number} páginas`
  else
    p(class='text-primary-200') No hay libros con más de #{min_pages} páginas