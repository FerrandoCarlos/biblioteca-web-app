extends ../layout/layout.pug

block metadata  
	title Autores del Libro | Biblioteca 
	meta(name="description", content="Fotos de autores del libro")

block content
	include ../mixins/components.pug
	div(class="flex justify-between items-center mb-6")
		h1(class="text-2xl font-medium text-primary-900") Autores del libro 
		a(href="/books" class="px-4 py-2 rounded-lg border border-primary-600 text-primary-600 hover:bg-primary-50 transition-colors") Volver 
	if authors && authors.length 
		div(class="grid grid-cols-2 gap-6")
			each author in authors 
				+card()
					div(class="flex flex-col items-center gap-3")
						if author.photo 
							img(class="w-24 h-24 rounded-full object-cover" src=author.photo alt=`${author.first_name} ${author.last_name}`)
						else 
							div(class='w-24 h-24 rounded-full bg-primary-200 flex items-center justify-center')
                span(class='text-2xl font-medium text-primary-800')= author.first_name[0] + author.last_name[0]
            p(class='font-medium text-primary-900')= `${author.first_name} ${author.last_name}`
            p(class='text-sm text-primary-200')= author.email
  else
    p(class='text-primary-200') No hay autores para este libro