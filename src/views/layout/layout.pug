doctype html
html(lang='es')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    block metadata
      title Biblioteca App
      meta(name='description', content='Sistema de gestión de biblioteca')
    script(src='https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4')
    style(type='text/tailwindcss').
      @theme {
        --color-primary-50: #EEEDFE;
        --color-primary-200: #AFA9EC;
        --color-primary-600: #534AB7;
        --color-primary-800: #3C3489;
        --color-primary-900: #26215C;
        --color-teal-200: #5DCAA5;
        --color-teal-400: #1D9E75;
        --color-teal-800: #085041;
        --color-coral-200: #F0997B;
        --color-coral-600: #993C1D;
      }
  body.bg-primary-50.min-h-screen.flex.flex-col
    nav.bg-primary-900.text-primary-50.px-6.py-4
      div.max-w-6xl.mx-auto.flex.justify-between.items-center
        a.text-xl.font-medium.tracking-wide(href='/') 📚 Biblioteca
        ul.flex.gap-6
          li
            a(href='/genres' class='hover:text-teal-200 transition-colors') Géneros
          li
            a(href='/authors' class='hover:text-teal-200 transition-colors') Autores
          li
            a(href='/books' class='hover:text-teal-200 transition-colors') Libros
    main.max-w-6xl.mx-auto.w-full.px-6.py-8.flex-1
      block content
    footer.bg-primary-900.text-primary-200.text-center.py-4.mt-8
      p Biblioteca App &copy; 2025 — Programación Web II - By MiloDev